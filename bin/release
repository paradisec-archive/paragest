#!/usr/bin/env bash

set -e

switch_to_main() {
  echo "Switching back to main branch..."
  git checkout main
}

usage() {
  echo "Usage: bin/release <stage|prod> [--branch]"
  exit 1
}

ENV=""
BRANCH_MODE=false
for arg in "$@"; do
  case $arg in
    --branch) BRANCH_MODE=true ;;
    stage | prod) ENV=$arg ;;
    *) usage ;;
  esac
done

if [ -z "$ENV" ]; then
  usage
fi

if [ "$BRANCH_MODE" = true ] && [ "$ENV" != "stage" ]; then
  echo "--branch can only be used with stage."
  exit 1
fi

if [ "$BRANCH_MODE" = true ]; then
  # Deploy the current branch as-is: no main check, no stage branch update,
  # and we stay on the branch afterwards
  echo "Deploying branch $(git branch --show-current) to stage..."
  git push --set-upstream origin HEAD
else
  trap 'switch_to_main' ERR

  # Check on main branch
  if [ "$(git branch --show-current)" != "main" ]; then
    echo "You must be on the main branch to release."
    exit 1
  fi

  git push
  git switch "$ENV"
  git merge --ff-only main
  git push
fi

AWS_PROFILE=nabu-${ENV} pnpm run cdk deploy

# Cleanup cdk
# Echo cleaning up!!
pnpm run cdk-agc

RELEASE_NAME=$(git rev-parse --short HEAD)

COMMON="--org nabu-d0 --project paragest"
# shellcheck disable=SC2086 # We do want word splitting here
pnpm exec sentry-cli releases $COMMON new "$RELEASE_NAME"
# shellcheck disable=SC2086 # We do want word splitting here
pnpm exec sentry-cli releases $COMMON set-commits --auto "$RELEASE_NAME"
# shellcheck disable=SC2086 # We do want word splitting here
pnpm exec sentry-cli releases $COMMON finalize "$RELEASE_NAME"

echo "Sentry release $RELEASE_NAME created."

if [ "$BRANCH_MODE" = false ]; then
  switch_to_main
fi
